{
  "name": "@seen/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/app.ts",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    },
    "./tmdb": {
      "types": "./src/modules/tmdb/model.ts",
      "default": "./src/modules/tmdb/model.ts"
    },
    "./platforms": {
      "types": "./src/modules/platforms/model.ts",
      "default": "./src/modules/platforms/model.ts"
    },
    "./preferences": {
      "types": "./src/modules/preferences/model.ts",
      "default": "./src/modules/preferences/model.ts"
    },
    "./recommendations": {
      "types": "./src/modules/recommendations/model.ts",
      "default": "./src/modules/recommendations/model.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "bun test",
    "dev:trigger": "bunx trigger.dev@latest dev",
    "deploy:trigger": "bunx trigger.dev@latest deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.946.0",
    "@aws-sdk/s3-request-presigner": "^3.946.0",
    "@better-auth/drizzle-adapter": "^1.6.14",
    "@better-auth/expo": "^1.6.14",
    "@elysia/cors": "^1.4.0",
    "@elysia/eden": "^1.4.10",
    "@seen/db": "workspace:*",
    "@seen/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "@trigger.dev/sdk": "^4.0.0",
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.17",
    "fflate": "^0.8.3",
    "ioredis": "^5.8.2",
    "jose": "^6.2.3",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@trigger.dev/build": "^4.0.0",
    "@types/bun": "^1.3.1",
    "trigger.dev": "^4.0.0",
    "typescript": "~6.0.3"
  }
}
