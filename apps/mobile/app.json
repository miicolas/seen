{
  "expo": {
    "name": "Seen",
    "slug": "seenbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seen",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.seen.com",
      "icon": "./assets/seen.icon",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": [
          "en",
          "fr",
          "en",
          "fr"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Seen uses your contacts to help you find friends who are already on Seen. Your contacts are matched privately and never stored in plain text."
      },
      "appleTeamId": "HZAYG4Q47N"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Seen utilise ta photothèque pour choisir ta photo de profil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-contacts",
        {
          "contactsPermission": "Seen uses your contacts to help you find friends who are already on Seen. Your contacts are matched privately and never stored in plain text."
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": [
            "en",
            "fr"
          ]
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "app.seen.com.ExpoWidgetsTarget",
          "groupIdentifier": "group.app.seen.com",
          "enablePushNotifications": false,
          "widgets": []
        }
      ],
      "./plugins/with-expo-widgets-version"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f5bacb4d-9027-4a2c-88d9-221a1ea91c3d"
      }
    },
    "owner": "miicolass",
    "updates": {
      "url": "https://u.expo.dev/f5bacb4d-9027-4a2c-88d9-221a1ea91c3d"
    }
  }
}
