{
  "name": "@seen/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.0",
    "pg": "^8.16.3",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "typescript": "~6.0.3"
  }
}
